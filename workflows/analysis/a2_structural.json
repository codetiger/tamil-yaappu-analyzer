{
  "id": "analysis_a2_structural",
  "name": "A2 Structural Tags",
  "channel": "analysis",
  "priority": 2,
  "version": 1,
  "status": "active",
  "tasks": [
    {
      "id": "a2_valid_tamil",
      "name": "A2: Valid Tamil Script",
      "function": {
        "name": "map",
        "input": {
          "mappings": [
            {
              "path": "data.analysis.tags.valid_tamil",
              "logic": {"none": [{"var": "data.paa.sorkal"}, {"==": [{"var": "is_valid_script"}, false]}]}
            }
          ]
        }
      }
    },
    {
      "id": "a2_no_empty",
      "name": "A2: No Empty Words",
      "function": {
        "name": "map",
        "input": {
          "mappings": [
            {
              "path": "data.analysis.tags.no_empty_words",
              "logic": {"none": [{"var": "data.paa.sorkal"}, {"==": [{"var": "is_empty"}, true]}]}
            }
          ]
        }
      }
    },
    {
      "id": "a2_sol_per_adi",
      "name": "A2: Words Per Line",
      "function": {
        "name": "map",
        "input": {
          "mappings": [
            {
              "path": "data.analysis.tags.sol_per_adi",
              "logic": {"map": [{"var": "data.paa.adikal"}, {"var": "logical_sol_count"}]}
            }
          ]
        }
      }
    }
  ]
}
