        "name": "map",
        "input": {
          "mappings": [
            {
              "path": "data.analysis.tags.thalai_all_valid",
              "logic": {
                "none": [
                  {"var": "data.paa.thalaikal"},
                  { "and": [
                    {"==": [{"var": "is_intra_compound"}, false]},
                    {"==": [{"var": "is_to_eetru"}, false]},
                    {"==": [{"var": "thalai_valid"}, false]}
                  ]}
                ]
              }
            }
          ]
        }
      }
    },
    {
      "id": "a4_thalai_types",
      "name": "A4: Junction Types",
      "function": {
        "name": "map",
        "input": {
          "mappings": [
            {
              "path": "data.analysis.tags.thalai_types",
              "logic": {"map": [{"var": "data.paa.thalaikal"}, {"var": "thalai_type"}]}
            }
          ]
        }
      }
    }
  ]
