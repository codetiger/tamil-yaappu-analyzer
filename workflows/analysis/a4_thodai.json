{
  "id": "analysis_a4_thodai",
  "name": "A4 Thodai (Rhyme & Pattern) Analysis",
  "channel": "analysis",
  "priority": 4,
  "version": 1,
  "status": "active",
  "tasks": [
    {
      "id": "a4_rhyme_data",
      "name": "A4: Compute rhyme_id_list, kadai_list, monai_list with refs",
      "function": {
        "name": "map",
        "input": {
          "mappings": [
            {
              "path": "temp_data.rhyme_id_list",
              "logic": {
                "map": [
                  {"var": "data.paa.adikal"},
                  {"var": "sorkal.0.irandaam_ezhuthu"}
                ]
              }
            },
            {
              "path": "temp_data.rhyme_refs",
              "logic": {
                "reduce": [
                  {"var": "data.paa.adikal"},
                  {
                    "refs": {"merge": [
                      {"var": "accumulator.refs"},
                      [{"cat": ["word.", {"var": "accumulator.idx"}, ".0.irandaam_ezhuthu"]}]
                    ]},
                    "idx": {"+": [{"var": "accumulator.idx"}, 1]}
                  },
                  {"refs": [], "idx": 0}
                ]
              }
            },
            {
              "path": "temp_data.kadai_list",
              "logic": {
                "map": [
                  {"var": "data.paa.adikal"},
                  {"reduce": [
                    {"var": "sorkal"},
                    {"var": "current.kadai_ezhuthu"},
                    null
                  ]}
                ]
              }
            },
            {
              "path": "temp_data.kadai_refs",
              "logic": {
                "reduce": [
                  {"var": "data.paa.adikal"},
                  {
                    "refs": {"merge": [
                      {"var": "accumulator.refs"},
                      [{"cat": ["word.", {"var": "accumulator.idx"}, ".", {"-": [{"length": {"var": "current.sorkal"}}, 1]}, ".kadai_ezhuthu"]}]
                    ]},
                    "idx": {"+": [{"var": "accumulator.idx"}, 1]}
                  },
                  {"refs": [], "idx": 0}
                ]
              }
            },
            {
              "path": "temp_data.monai_list",
              "logic": {
                "map": [
                  {"var": "data.paa.adikal"},
                  {"var": "sorkal.0.muthal_ezhuthu"}
                ]
              }
            },
            {
              "path": "temp_data.monai_refs",
              "logic": {
                "reduce": [
                  {"var": "data.paa.adikal"},
                  {
                    "refs": {"merge": [
                      {"var": "accumulator.refs"},
                      [{"cat": ["word.", {"var": "accumulator.idx"}, ".0.muthal_ezhuthu"]}]
                    ]},
                    "idx": {"+": [{"var": "accumulator.idx"}, 1]}
                  },
                  {"refs": [], "idx": 0}
                ]
              }
            }
          ]
        }
      }
    },
    {
      "id": "a4_unique_sets",
      "name": "A4: Compute unique sets for rhyme, kadai, monai",
      "function": {
        "name": "map",
        "input": {
          "mappings": [
            {
              "path": "temp_data.unique_rhymes",
              "logic": {
                "reduce": [
                  {"var": "temp_data.rhyme_id_list"},
                  {"?:": [
                    {"in": [{"var": "current"}, {"var": "accumulator"}]},
                    {"var": "accumulator"},
                    {"merge": [{"var": "accumulator"}, [{"var": "current"}]]}
                  ]},
                  []
                ]
              }
            },
            {
              "path": "temp_data.unique_kadai",
              "logic": {
                "reduce": [
                  {"var": "temp_data.kadai_list"},
                  {"?:": [
                    {"in": [{"var": "current"}, {"var": "accumulator"}]},
                    {"var": "accumulator"},
                    {"merge": [{"var": "accumulator"}, [{"var": "current"}]]}
                  ]},
                  []
                ]
              }
            },
            {
              "path": "temp_data.unique_monai",
              "logic": {
                "reduce": [
                  {"var": "temp_data.monai_list"},
                  {"?:": [
                    {"in": [{"var": "current"}, {"var": "accumulator"}]},
                    {"var": "accumulator"},
                    {"merge": [{"var": "accumulator"}, [{"var": "current"}]]}
                  ]},
                  []
                ]
              }
            }
          ]
        }
      }
    },
    {
      "id": "a4_rhyme_analysis",
      "name": "A4: Etukai, Monai, Iyaipu, Vikarpam analysis",
      "function": {
        "name": "map",
        "input": {
          "mappings": [
            {
              "path": "data.analysis.tags.etukai",
              "logic": {
                "value": {"==": [{"length": {"var": "temp_data.unique_rhymes"}}, 1]},
                "refs": {"var": "temp_data.rhyme_refs.refs"}
              }
            },
            {
              "path": "data.analysis.tags.monai",
              "logic": {
                "value": {"==": [{"length": {"var": "temp_data.unique_monai"}}, 1]},
                "refs": {"var": "temp_data.monai_refs.refs"}
              }
            },
            {
              "path": "data.analysis.tags.is_iyaipu",
              "logic": {
                "value": {"==": [{"length": {"var": "temp_data.unique_kadai"}}, 1]},
                "refs": {"var": "temp_data.kadai_refs.refs"}
              }
            },
            {
              "path": "data.analysis.tags.vikarpam_count",
              "logic": {"length": {"var": "temp_data.unique_rhymes"}}
            },
            {
              "path": "data.analysis.tags.vikarpam_type",
              "logic": {"switch": [
                {"length": {"var": "temp_data.unique_rhymes"}},
                [[1, "oru_vikarpam"], [2, "iru_vikarpam"]],
                "pala_vikarpam"
              ]}
            },
            {
              "path": "temp_data.rhyme_schema_reduce",
              "logic": {
                "reduce": [
                  {"var": "temp_data.rhyme_id_list"},
                  {
                    "schema": {"merge": [
                      {"var": "accumulator.schema"},
                      [{"if": [
                        {"==": [{"var": "current"}, {"var": "accumulator.seen.0"}]}, "A",
                        {"==": [{"var": "current"}, {"var": "accumulator.seen.1"}]}, "B",
                        {"==": [{"var": "current"}, {"var": "accumulator.seen.2"}]}, "C",
                        {"==": [{"length": {"var": "accumulator.seen"}}, 0]}, "A",
                        {"==": [{"length": {"var": "accumulator.seen"}}, 1]}, "B",
                        {"==": [{"length": {"var": "accumulator.seen"}}, 2]}, "C",
                        "D"
                      ]}]
                    ]},
                    "seen": {"if": [
                      {"in": [{"var": "current"}, {"var": "accumulator.seen"}]},
                      {"var": "accumulator.seen"},
                      {"merge": [{"var": "accumulator.seen"}, [{"var": "current"}]]}
                    ]}
                  },
                  {"schema": [], "seen": []}
                ]
              }
            },
            {
              "path": "data.analysis.tags.rhyme_schema",
              "logic": {"var": "temp_data.rhyme_schema_reduce.schema"}
            }
          ]
        }
      }
    }
  ]
}
