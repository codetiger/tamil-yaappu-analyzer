{
  "id": "analysis_a6_classify",
  "name": "A6 Classification (post-tags)",
  "channel": "analysis",
  "priority": 6,
  "version": 5,
  "status": "active",
  "tasks": [
    {
      "id": "a6_paa_family",
      "name": "A6: Paa Family Classification",
      "function": {
        "name": "map",
        "input": {
          "mappings": [
            {
              "path": "data.analysis.classification.paa_family",
              "logic": { "if": [
                { "and": [
                  {"==": [{"var": "data.analysis.tags.valid_tamil"}, true]},
                  {"==": [{"var": "data.analysis.tags.no_empty_words"}, true]},
                  {"==": [{"var": "data.analysis.tags.syllabification_ok"}, true]},
                  {
                    "in": [
                      {"var": "data.analysis.tags.eetru_type"},
                      ["naal", "malar", "kaasu", "pirappu"]
                    ]
                  },
                  {"==": [{"var": "data.analysis.tags.has_overflow"}, false]},
                  {">=": [{"length": {"var": "data.paa.adikal"}}, 2]},
                  {
                    "all": [
                      {"slice": [{"var": "data.analysis.tags.sol_per_adi"}, 0, -1]},
                      {"==": [{"var": ""}, 4]}
                    ]
                  },
                  {"==": [{"slice": [{"var": "data.analysis.tags.sol_per_adi"}, -1]}, [3]]}
                ]},
                "venba",
                "unknown"
              ]}
            }
          ]
        }
      }
    },
    {
      "id": "a6_venba_type",
      "name": "A6: Venba Sub-Type Classification (by line count)",
      "function": {
        "name": "map",
        "input": {
          "mappings": [
            {
              "path": "data.analysis.classification.venba_type",
              "logic": { "if": [
                { "and": [
                  {"==": [{"var": "data.analysis.classification.paa_family"}, "venba"]},
                  {"==": [{"length": {"var": "data.paa.adikal"}}, 2]}
                ]},
                "kural_venba",
                { "and": [
                  {"==": [{"var": "data.analysis.classification.paa_family"}, "venba"]},
                  {"==": [{"length": {"var": "data.paa.adikal"}}, 3]}
                ]},
                "sindhiyal_venba",
                { "and": [
                  {"==": [{"var": "data.analysis.classification.paa_family"}, "venba"]},
                  {"==": [{"length": {"var": "data.paa.adikal"}}, 4]}
                ]},
                "alaviyal_venba",
                { "and": [
                  {"==": [{"var": "data.analysis.classification.paa_family"}, "venba"]},
                  {">=": [{"length": {"var": "data.paa.adikal"}}, 5]},
                  {"<=": [{"length": {"var": "data.paa.adikal"}}, 12]}
                ]},
                "pahrodai_venba",
                { "and": [
                  {"==": [{"var": "data.analysis.classification.paa_family"}, "venba"]},
                  {">=": [{"length": {"var": "data.paa.adikal"}}, 13]}
                ]},
                "kali_venba",
                "unknown"
              ]}
            }
          ]
        }
      }
    }
  ]
}
