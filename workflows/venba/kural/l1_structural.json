{
  "id": "kural_l1_structural",
  "name": "Kural Venba L1 Structural Validation",
  "channel": "venba_kural",
  "priority": 1,
  "version": 1,
  "status": "active",
  "tasks": [
    {
      "id": "l1_1_word_count",
      "name": "L1-1: Word Count Check",
      "function": {
        "name": "validation",
        "input": {
          "rules": [
            {
              "logic": {
                "==": [
                  {"var": "data.paa.original_sol_count"},
                  7
                ]
              },
              "message": "E_WORD_COUNT: Expected exactly 7 words in Kural Venba"
            }
          ]
        }
      }
    },
    {
      "id": "l1_2a_line_count",
      "name": "L1-2a: Line Count Check",
      "function": {
        "name": "validation",
        "input": {
          "rules": [
            {
              "logic": {
                "==": [
                  {"length": {"var": "data.paa.adikal"}},
                  2
                ]
              },
              "message": "E_LINE_COUNT: Expected exactly 2 lines in Kural Venba"
            }
          ]
        }
      }
    },
    {
      "id": "l1_2b_line1_split",
      "name": "L1-2b: Line 1 Must Have 4 Words",
      "function": {
        "name": "validation",
        "input": {
          "rules": [
            {
              "logic": {
                "==": [
                  {"var": "data.paa.adikal.0.logical_sol_count"},
                  4
                ]
              },
              "message": "E_LINE_SPLIT: Line 1 must have exactly 4 words"
            }
          ]
        }
      }
    },
    {
      "id": "l1_2c_line2_split",
      "name": "L1-2c: Line 2 Must Have 3 Words",
      "function": {
        "name": "validation",
        "input": {
          "rules": [
            {
              "logic": {
                "==": [
                  {"var": "data.paa.adikal.1.logical_sol_count"},
                  3
                ]
              },
              "message": "E_LINE_SPLIT: Line 2 must have exactly 3 words"
            }
          ]
        }
      }
    },
    {
      "id": "l1_3_script_check",
      "name": "L1-3: Tamil Script Validation",
      "function": {
        "name": "validation",
        "input": {
          "rules": [
            {
              "logic": {
                "all": [
                  {"var": "data.paa.sorkal"},
                  {"var": "is_valid_script"}
                ]
              },
              "message": "E_INVALID_SCRIPT: One or more words contain non-Tamil characters"
            }
          ]
        }
      }
    },
    {
      "id": "l1_4_empty_check",
      "name": "L1-4: Empty Word Check",
      "function": {
        "name": "validation",
        "input": {
          "rules": [
            {
              "logic": {
                "none": [
                  {"var": "data.paa.sorkal"},
                  {"var": "is_empty"}
                ]
              },
              "message": "E_EMPTY_WORD: One or more words are empty"
            }
          ]
        }
      }
    }
  ]
}
